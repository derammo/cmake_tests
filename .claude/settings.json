{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Read(/*)",
            "Bash(npm run lint)",
            "Bash(npm run test *)",
            "Bash(sh tests/test_*.sh)",
            "Bash(make test 2>&1 *)",
            "Bash(git checkout -b fix/*)",
            "Bash(git add *)",
            "Bash(git commit -m *)",
            "Bash(git push origin fix/*)",
            "Bash(git push -u origin fix/*)",
            "Bash(git checkout main)",
            "Bash(git submodule status)",
            "Bash(git fetch origin)",
            "Bash(git branch --show-current)",
            "Bash(git status)",
            "Bash(echo \"exit=$?\")",
            "Bash(cd /Users/ammo/src/git/cmake_tests)",
            "Bash(cd /Users/ammo/src/git/cmake_tests/*)",
            "Bash(tail *)",
            "Bash(grep *)",
            "Bash(cd /Users/ammo/src/git/cmake_tests && make test 2>&1 | grep -E '^\\[|^==>|^passed')",
            "Bash(/Users/ammo/.claude/bin/gh-bot pr create *)",
            "Bash(/Users/ammo/.claude/bin/gh-bot auth status)",
            "Bash(/Users/ammo/.claude/bin/gh-bot api user)"
        ],
        "deny": [
            "Bash(curl *)",
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)"
        ]
    }
}